# Training data — large, regenerable, lives on disk outside git.
# The synthetic_dataset is a symlink to ~/Desktop/synthetic_dataset
# (~500 classes, 268k+ PNG renders, 5.8 GB); Nature 2023 corpus is ~40 GB
# under ml/data/nature_2023/. Neither should ever enter git.
ml/data/synthetic_dataset
ml/data/nature_2023/*
!ml/data/nature_2023/README.md
!ml/data/nature_2023/.gitkeep
ml/data/renders/
ml/data/test_renders/
ml/data/training_data/
ml/data/huggingface_legobricks/
ml/data/*.zip
ml/data/*.tar
ml/data/*.tar.gz
ml/data/synthetic_dataset_dr_pilot/
ml/data/catalog_image_cache/
ml/data/eval_results/
ml/data/models/
ml/blender/hdris

# …but track the canonical model bundles the backend loads at startup
# (everything else stays excluded).
!backend/models/lego_classifier.onnx
!backend/models/lego_classifier.onnx.data
# The fp32 yolo_lego.onnx (167 MB) is NOT tracked — exceeds GitHub's 100 MB
# file-size limit. Keep a local copy for running the int8 quant script; the
# int8 derivative (58 MB) is what actually ships.
!backend/models/yolo_lego.int8.onnx
!backend/models/yolo_lego.results.csv

# Mobile bundles the int8 detector into the app via Expo's asset pipeline —
# must be tracked so EAS/expo build picks it up. 58 MB, regenerable via
# `ml/export/quantize_yolo_int8.py` if the blob ever gets lost.
!mobile/assets/models/
!mobile/assets/models/yolo_lego.int8.onnx

# Trained-model local state — not committed
backend/models/*.mystery_backup
# Duplicate of lego_classifier.onnx.data — the ONNX graph has this
# filename baked in internally, so it's needed at runtime, but it's
# regenerable via `cp lego_classifier.onnx.data mobilenetv3_lego.onnx.data`.
backend/models/mobilenetv3_lego.onnx.data
# Emitted by ml/scripts/calibrate_temperatures.py — regenerable from feedback DB
backend/data/calibration_temperatures.json
# Emitted by ml/scripts/precompute_clip_catalog.py — regenerable in ~1 min
backend/data/embeddings_cache.pkl
backend/data/embeddings_cache.misses.txt

# ML model backup directories (local rollback only, do not commit)
backend/models/backup_*/
backend/app/ml/models/

# Stale symlink artifact (external-data file aliased for ONNX loader)
backend/models/best.onnx.data

# Orphaned ONNX external-data files. onnxruntime.quantization.quant_pre_process
# occasionally drops GUID-named .data siblings in the working directory when
# it reshuffles external weights. Catch them at the repo root so a rogue
# `git add .` doesn't push 166 MB to GitHub.
/*.data
/*.onnx

# macOS Finder duplication artifacts. When two apps touch the same file at
# the same time Finder sometimes writes `Foo 2.ext`. We never commit those.
**/* 2.lock
**/* 2.json
**/* 2.yml
**/* 2.yaml

# Spark-side snapshot downloads — local reference copies of models trained on
# the DGX. The canonical backend model lives at backend/models/lego_classifier.onnx.
backend/models/spark_*/
